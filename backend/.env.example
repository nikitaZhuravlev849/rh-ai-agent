# База данных (имена хостов = имена сервисов в docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/rh_ai_agent
REDIS_URL=redis://redis:6379/0

# LLM (обязательно для генерации писем и ТЗ)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# HH.ru парсинг (опционально)
HH_API_TOKEN=
HH_API_URL=https://api.hh.ru

# SuperJob парсинг (опционально)
SUPERJOB_API_KEY=
SUPERJOB_API_URL=https://api.superjob.ru/2.0

# Email рассылка (опционально)
SENDGRID_API_KEY=
EMAIL_FROM=agent@procompetencies.ru
EMAIL_FROM_NAME=ProCompetencies Agent

# LinkedIn (опционально)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Безопасность
SECRET_KEY=dev_secret_key_change_in_production_32chars
DEBUG=True

# CORS — ВАЖНО: JSON-массив без пробелов внутри
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Настройки фолоу-апов
FOLLOWUP_DELAY_DAYS=7
FOLLOWUP_MAX_ATTEMPTS=2
